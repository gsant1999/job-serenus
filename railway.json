{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "nixpacks"
  },
  "deploy": {
    "numReplicas": 1,
    "startCommand": "python3 -u app.py",
    "restartPolicyMaxRetries": 3,
    "restartPolicyWindowSeconds": 600
  },
  "volumes": [
    {
      "name": "data",
      "mountPath": "/data",
      "size": "10GB"
    }
  ]
}
