# ============================================================================
# JOB — variáveis de ambiente de uma INSTÂNCIA DE CLIENTE (white-label)
# ============================================================================
# Cada corretora cliente roda seu PRÓPRIO deploy com seu PRÓPRIO banco (vazio).
# O mesmo código do Serenus serve a todos — o que muda é isto aqui.
# A instância do Serenus NÃO seta as BRAND_/SEED_/MODO_ — usa os defaults.
# Copie este arquivo pras variáveis do Railway do cliente e preencha.

# ── OBRIGATÓRIAS (a instância não sobe / não isola sem elas) ─────────────────
DATABASE_URL=            # Postgres do cliente (Railway cria; cole a URL aqui)
SECRET_KEY=             # string aleatória longa (sessões). NUNCA reutilizar entre clientes
WHATSAPP_EXT_KEY=       # chave que a extensão usa pra falar com ESTA instância

# ── ISOLAMENTO (o que impede vazar dado/marca do Serenus) ────────────────────
MODO_OPERADOR=0         # 0 = esconde as ferramentas de infra/suporte do admin do cliente
                        #     (nós ligamos =1 só quando formos dar suporte à instância dele)
SEED_DADOS_SERENUS=0    # 0 = banco novo NÃO recebe comissões/recebimento/Affinity do Serenus
SEED_ADMIN_NOME=        # nome do 1o admin (o dono da corretora cliente)
SEED_ADMIN_EMAIL=       # e-mail do 1o admin (login inicial)
SEED_ADMIN_SENHA=       # senha inicial do 1o admin (peça pra trocar no 1o acesso)

# ── MARCA (white-label) ──────────────────────────────────────────────────────
BRAND_NOME=             # ex: "Acme Corretora de Saúde" (nome completo)
BRAND_NOME_CURTO=       # ex: "Acme" (aparece no menu, títulos, extensão, rótulos)
BRAND_CORRETORA=        # ex: "Corretora Acme" (rodapés "by ...")
BRAND_ANO=2026          # ano do rodapé
BRAND_SUPORTE_EMAIL=    # e-mail de suporte do cliente
BRAND_LOGO_URL=         # URL pública do logo do cliente (default = logo do Serenus)

# ── INTEGRAÇÕES (cada cliente com as SUAS chaves; deixe vazio o que não usar) ─
ANTHROPIC_API_KEY=      # análise de conversa (Claude). Sem ela, a análise por IA não roda
GROQ_API_KEY=           # transcrição de áudio (barata). Fallback: OPENAI_API_KEY
OPENAI_API_KEY=         # transcrição fallback (opcional)
BREVO_API_KEY=          # envio de e-mail (opcional)
ASAAS_API_KEY=          # pagamento PIX a consultores (opcional)
SMTP_USER=              # remetente de e-mail (opcional)
GTISMS_API_KEY=         # envio de SMS (opcional)
WASPEED_TOKEN=          # WhatsApp pessoal via WaSpeed (opcional, por consultor no cadastro)
API_KEY_BI=             # chave da API de BI (opcional)
SHEETS_WEBHOOK_TOKEN=   # token do webhook de intake de leads por planilha (se o cliente usar)

# ── NÃO SETAR numa instância de cliente (são do Serenus) ─────────────────────
# BOTCONVERSA_API_KEY / BOTCONVERSA_WEBHOOK_TOKEN  -> integração só do Serenus
# (as rotas/telas do Serenus já somem sozinhas quando a marca != Serenus)

# ── AJUSTES FINOS (opcionais — têm default sensato) ──────────────────────────
# CUSTO_MAX_ANALISE_BRL=1.00       # teto de custo de IA por análise
# USD_BRL_TAXA=5.10                # câmbio pra estimar custo
# CLAUDE_MODEL / CLAUDE_MODEL_DOCS / CLAUDE_MODEL_DESCREVER  # modelos
